---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline";
  size?: "sm" | "md" | "lg";
}

const { href, variant = "primary", size = "md" } = Astro.props;
const Tag = href ? "a" : "button";
---

<Tag
  class={`ab-btn ab-btn--${variant} ab-btn--${size}`}
  {...(href ? { href } : { type: "button" })}
>
  <slot />
</Tag>

<style>
  .ab-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s, box-shadow 0.15s;
    border: none;
  }

  .ab-btn--sm { padding: 0.375rem 0.75rem; font-size: 0.8rem; }
  .ab-btn--md { padding: 0.5rem 1rem; font-size: 0.9rem; }
  .ab-btn--lg { padding: 0.625rem 1.5rem; font-size: 1rem; }

  .ab-btn--primary {
    background: #3b82f6;
    color: #fff;
  }
  .ab-btn--primary:hover { background: #2563eb; }

  .ab-btn--secondary {
    background: #64748b;
    color: #fff;
  }
  .ab-btn--secondary:hover { background: #475569; }

  .ab-btn--outline {
    background: transparent;
    color: #3b82f6;
    box-shadow: inset 0 0 0 1px #3b82f6;
  }
  .ab-btn--outline:hover { background: #eff6ff; }
</style>
