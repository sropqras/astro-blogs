---
import { LocalAdapter } from "@astro-blogs/core";
import Card from "@astro-blogs/components/Card.astro";
import Grid from "@astro-blogs/components/Grid.astro";

const adapter = new LocalAdapter("./src/content/posts");

export async function getStaticPaths() {
  const adapter = new LocalAdapter("./src/content/posts");
  const tags = await adapter.getAllTags();
  return tags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = await adapter.getPostsByTag(tag!);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tag: {tag} — astro-blogs Demo</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 64rem;
        margin: 0 auto;
        padding: 2rem 1rem;
        color: #1e293b;
      }
      h1 { font-size: 2rem; margin-bottom: 0.5rem; }
      .subtitle { color: #64748b; margin-bottom: 2rem; }
      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: #3b82f6;
        text-decoration: none;
      }
      .back-link:hover { text-decoration: underline; }
      .tag-badge {
        display: inline-block;
        background: #3b82f6;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <a href="/tags" class="back-link">&larr; All tags</a>
    <h1>
      Posts tagged <span class="tag-badge">{tag}</span>
    </h1>
    <p class="subtitle">{posts.length} post{posts.length !== 1 ? "s" : ""}</p>

    <Grid columns={2}>
      {posts.map((post) => (
        <Card title={post.title} href={`/posts/${post.slug}`}>
          <p>{post.description ?? ""}</p>
          <small>{new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</small>
        </Card>
      ))}
    </Grid>
  </body>
</html>
