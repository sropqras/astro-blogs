---
import { LocalAdapter } from "@astro-blogs/core";

const adapter = new LocalAdapter("./src/content/posts");
const tags = await adapter.getAllTags();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tags — astro-blogs Demo</title>
    <style>
      body {
        font-family: system-ui, sans-serif;
        max-width: 64rem;
        margin: 0 auto;
        padding: 2rem 1rem;
        color: #1e293b;
      }
      h1 { font-size: 2rem; margin-bottom: 0.5rem; }
      .subtitle { color: #64748b; margin-bottom: 2rem; }
      .tags-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        list-style: none;
        padding: 0;
      }
      .tag-link {
        display: inline-block;
        background: #f1f5f9;
        color: #334155;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        text-decoration: none;
        font-size: 0.9375rem;
        transition: background 0.15s;
      }
      .tag-link:hover {
        background: #e2e8f0;
        color: #0f172a;
      }
      .back-link {
        display: inline-block;
        margin-bottom: 1.5rem;
        color: #3b82f6;
        text-decoration: none;
      }
      .back-link:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <a href="/" class="back-link">&larr; Back to home</a>
    <h1>Tags</h1>
    <p class="subtitle">Browse posts by tag</p>

    {tags.length > 0 ? (
      <ul class="tags-list">
        {tags.map((tag) => (
          <li>
            <a href={`/tags/${tag}`} class="tag-link">{tag}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p>No tags found.</p>
    )}
  </body>
</html>
